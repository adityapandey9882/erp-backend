NODE_ENV=development
PORT=4000
APP_NAME=Company Management ERP API
API_PREFIX=/api/v1
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/company_erp
DATABASE_POOL_MAX=10
DATABASE_SSL=false
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DOCUMENT_BUCKET=company-documents
AUTH_JWT_SECRET=change-this-development-secret
AUTH_JWT_EXPIRES_IN_SECONDS=28800
AUTH_BOOTSTRAP_USER_ID=00000000-0000-0000-0000-000000000001
AUTH_BOOTSTRAP_NAME=ERP Superadmin
AUTH_BOOTSTRAP_EMAIL=superadmin@companyerp.local
AUTH_BOOTSTRAP_PASSWORD=Admin@12345
AUTH_BOOTSTRAP_PASSWORD_HASH=
AUTH_BOOTSTRAP_ROLE=superadmin
AUTH_BOOTSTRAP_PERMISSIONS=*
